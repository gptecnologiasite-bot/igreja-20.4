  {
    "id": "TC008",
    "title": "Login and access the admin panel (/painel)",
    "description": "Verifies that an admin can log in via /login and reach the admin panel.",
    "category": "Admin Panel (Site Content Management)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/painel\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Painel\" is visible"
      }
    ]
  },
  {
    "id": "TC009",
    "title": "Save updated page content from admin panel and verify it appears on /kids",
    "description": "Verifies editing a page (title and text) in the admin panel saves successfully and is visible on the public page.",
    "category": "Admin Panel (Site Content Management)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/painel\""
      },
      {
        "type": "action",
        "description": "Click \"Select a page or ministry to edit\""
      },
      {
        "type": "action",
        "description": "Click the \"Kids\" option in the list"
      },
      {
        "type": "action",
        "description": "Fill \"Updated Kids Title\" into the title field"
      },
      {
        "type": "action",
        "description": "Fill \"Updated Kids description text for e2e test.\" into the text field"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Saved\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Kids\" link in the site navigation"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/kids\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Updated Kids Title\" is visible"
      }
    ]
  },
  {
    "id": "TC010",
